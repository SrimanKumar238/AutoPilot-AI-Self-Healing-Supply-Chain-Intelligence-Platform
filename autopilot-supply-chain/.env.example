# ─── Application ─────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-super-secret-key-32-chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ─────────────────────────────────────────────────
POSTGRES_USER=autopilot
POSTGRES_PASSWORD=autopilot_pass
POSTGRES_DB=supply_chain
DATABASE_URL=postgresql://autopilot:autopilot_pass@postgres:5432/supply_chain

# ─── PII Encryption ───────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASS=admin_pass
RABBITMQ_URL=amqp://admin:admin_pass@rabbitmq:5672/

# ─── Email / MFA ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
OTP_EXPIRE_MINUTES=5

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ─── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Observability ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=autopilot-backend
