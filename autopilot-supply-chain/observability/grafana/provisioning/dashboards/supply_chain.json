      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (handler) (rate(http_requests_total{job=\"autopilot-backend\"}[1m]))", "legendFormat": "{{handler}}", "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
