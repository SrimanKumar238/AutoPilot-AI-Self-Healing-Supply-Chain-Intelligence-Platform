      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(http_requests_in_progress{job=\"autopilot-backend\"}) or vector(0)", "legendFormat": "in progress", "refId": "A"}]
